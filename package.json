{
  "name": "shadcn-registry-mcp",
  "version": "1.0.0",
  "description": "MCP server for automated shadcn/ui component installation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shadcn-registry-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:bundle": "npm run build && mcpb pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["mcp", "shadcn", "ui", "components", "registry"],
  "license": "MIT"
}
